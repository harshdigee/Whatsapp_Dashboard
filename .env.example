# Optional overrides. Defaults in src/config/env.js already point at Railway production.

# Local Node backend instead of Railway:
# VITE_API_BASE_URL=http://localhost:5001/api
# VITE_SOCKET_URL=http://localhost:5001

# Vercel: only needed if you use a different API host than the default Railway URL.

# Supabase (required for Google OAuth gate)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
